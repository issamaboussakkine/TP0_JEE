# ============================================
# Issam : Fichier .gitignore personnalisé
# TP Connexion personnalisé - Issam
# Date : 28 Mars 2026
# ============================================

# -------------------------------
# Issam : Dossiers générés par Maven
# -------------------------------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# -------------------------------
# Issam : Fichiers IntelliJ IDEA
# Issam : Mon IDE principal pour le TP
# -------------------------------
.idea/modules.xml
.idea/jarRepositories.xml
.idea/compiler.xml
.idea/libraries/
*.iws
*.iml
*.ipr

# -------------------------------
# Issam : Fichiers Eclipse (si quelqu'un utilise Eclipse)
# -------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# -------------------------------
# Issam : Fichiers NetBeans
# -------------------------------
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# -------------------------------
# Issam : Fichiers VS Code
# -------------------------------
.vscode/

# -------------------------------
# Issam : Fichiers Mac OS (ignorer les fichiers système)
# -------------------------------
.DS_Store

# -------------------------------
# Issam : Fichiers de log (générés pendant l'exécution)
# -------------------------------
*.log
logs/

# -------------------------------
# Issam : Fichiers temporaires
# -------------------------------
*.tmp
*.temp
*.swp
*.swo

# -------------------------------
# Issam : Dossiers de sauvegarde
# -------------------------------
*.bak
*.backup

# -------------------------------
# Issam : Dossiers de configuration personnelle
# -------------------------------
.idea/
*.iml
out/

# -------------------------------
# Issam : Dossiers de compilation
# -------------------------------
**/build/
**/out/

# -------------------------------
# Issam : Fichiers de test (ne pas versionner les résultats)
# -------------------------------
**/test-output/
**/surefire-reports/

# -------------------------------
# Issam : Fichiers sensibles (ne jamais versionner)
# -------------------------------
application-secret.properties
*.key
*.p12
*.jks